# Supabase PostgreSQL connection string (Transaction pooler — port 6543)
# Found in: Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Admin API key for protected endpoints (POST /api/player-behavior, /api/clear-sessions, etc.)
ADMIN_API_KEY=your_secret_key_here
